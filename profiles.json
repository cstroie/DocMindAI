  "profiles": {
    "rra": {
      "id": "rra",
      "name": "Radiology Report Analyzer",
      "description": "Analyze radiology reports and extract key medical information",
      "category": "medical",
      "icon": "🔍",
      "prompt": "You are a medical assistant analyzing radiology reports.\n\nTASK: Read the report and extract the main pathological information in JSON format.\n\nCRITICAL INSTRUCTION: {language_instruction}\n\nOUTPUT FORMAT (JSON):\n{\n  \"pathologic\": \"yes/no\",\n  \"severity\": 1-10,\n  \"summary\": \"1-5 words\",\n  \"diagnoses\": [\"diagnosis1\", \"diagnosis2\", \"diagnosis3\"]\n}\n\nRULES:\n- \"pathologic\": \"yes\" if any anomaly exists, otherwise \"no\"\n- \"severity\": 1=minimal, 5=moderate, 10=critical/urgent\n- \"summary\": diagnosis in maximum 5 words (e.g., \"fracture\", \"pneumonia\", \"lung nodule\")\n- \"diagnoses\": exactly 3 specific medical diagnoses based on the report\n- If everything is normal: {\"pathologic\": \"no\", \"severity\": 0, \"summary\": \"normal\", \"diagnoses\": [\"normal\", \"no significant findings\", \"within normal limits\"]}\n- Ignore spelling errors\n- Respond ONLY with the JSON, without additional text",
      "form": {
        "fields": [
          {
            "name": "report_text",
            "type": "textarea",
            "label": "Radiology Report",
            "help": "Enter the radiology report you want to analyze. Maximum 10,000 characters.",
            "placeholder": "Example: Hazy opacity in the left mid lung field, possibly representing consolidation or infiltrate. No pleural effusion, pneumothorax or pneumoperitoneum.",
            "required": true
          },
          {
            "name": "model",
            "type": "select",
            "label": "AI Model",
            "help": "Select the AI model to use for analysis.",
            "options": []
          },
          {
            "name": "language",
            "type": "select",
            "label": "Response Language",
            "help": "Select the language for the AI response.",
            "options": []
          }
        ]
      }
    },
    "sde": {
      "id": "sde",
      "name": "Structured Data Extractor",
      "description": "Extract structured data from unstructured text",
      "category": "general",
      "icon": "📊",
      "prompt": "You are a data extraction API. Extract structured data from the following text:\n\nText: {text}\n\nReturn the extracted data in {output_format} format.",
      "form": {
        "fields": [
          {
            "name": "text",
            "type": "textarea",
            "label": "Input Text",
            "help": "Enter the text you want to extract structured data from. Maximum 10,000 characters.",
            "placeholder": "Example: Patient: John Doe, Age: 45, Diagnosis: Type 2 Diabetes, Treatment: Metformin 500mg twice daily",
            "required": true
          },
          {
            "name": "file",
            "type": "file",
            "label": "Upload File (optional)",
            "help": "Upload a file to extract data from (text documents or images). Max 10MB.",
            "accept": ".txt,.pdf,.doc,.docx,.odt,.md,.json,.csv,.xml,.png,.jpg,.jpeg,.gif,.webp",
            "required": false
          },
          {
            "name": "output_format",
            "type": "select",
            "label": "Output Format",
            "help": "Select the output format for the extracted data.",
            "options": [
              {"value": "json", "label": "JSON"},
              {"value": "yaml", "label": "YAML"},
              {"value": "xml", "label": "XML"},
              {"value": "markdown", "label": "Markdown"}
            ]
          },
          {
            "name": "model",
            "type": "select",
            "label": "AI Model",
            "help": "Select the AI model to use for data extraction.",
            "options": []
          },
          {
            "name": "max_image_size",
            "type": "select",
            "label": "Maximum Image Size",
            "help": "Select the maximum dimensions for resizing uploaded images. Choose 'Original' to send the image as-is without processing.",
            "options": [
              {"value": "original", "label": "Original"},
              {"value": "200", "label": "200x200"},
              {"value": "500", "label": "500x500"},
              {"value": "800", "label": "800x800"},
              {"value": "1000", "label": "1000x1000"}
            ]
          }
        ]
      }
    },
