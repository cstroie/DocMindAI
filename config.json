  "common": {
    "form": {
      "fields": [
        {
          "name": "model",
          "type": "select",
          "label": "AI Model",
          "help": "Select model for question generation",
          "options": []
        },
        {
          "name": "url",
          "type": "url",
          "label": "Or enter URL",
          "help": "Optionally provide a URL to fetch content from",
          "placeholder": "https://example.com/document",
          "required": false
        },
        {
          "name": "language",
          "type": "select",
          "label": "Response Language",
          "help": "Select output language",
          "options": []
        },
        {
          "name": "file",
          "type": "file",
          "label": "Upload File (optional)",
          "help": "Upload a text, document or image file. Max 5MB.",
          "accept": ".txt,.md,.doc,.docx,.pdf,.odt,text/plain,text/markdown,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/pdf,application/vnd.oasis.opendocument.text,image/jpeg,image/png,image/gif,image/webp",
          "required": false
        },
        {
          "name": "max_image_size",
          "type": "select",
          "label": "Maximum Image Size",
          "help": "Select maximum dimensions for uploaded images",
          "options": [
