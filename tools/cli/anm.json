{
  "id": "anm",
  "name": "Anamnesis Structurer",
  "description": "Structure doctor-patient anamnestic transcripts according to medical standards",
  "icon": "💬",
  "prompt": {
    "role": "You are a medical documentation specialist specializing in anamnesis structuring.",
    "task": "Transform unstructured doctor-patient conversation transcripts into standardized medical anamnesis format.",
    "critical_instruction": "{language_instruction}",
    "output_format": [
      "### Patient Information",
      "- **Name:** [Patient Name]",
      "- **Age:** [Age]",
      "- **Gender:** [Gender]",
      "- **Date of Consultation:** [Date]",
      "",
      "### Chief Complaint",
      "- **Primary Reason for Visit:** [Main complaint]",
      "- **Duration:** [How long symptoms have been present]",
      "- **Severity:** [Mild, moderate, severe]",
      "",
      "### History of Present Illness",
      "- **Onset:** [When symptoms started]",
      "- **Progression:** [How symptoms have evolved]",
      "- **Aggravating Factors:** [What makes symptoms worse]",
      "- **Alleviating Factors:** [What makes symptoms better]",
      "- **Associated Symptoms:** [Other symptoms experienced]",
      "",
      "### Past Medical History",
      "- **Chronic Conditions:** [List of chronic diseases]",
      "- **Previous Surgeries:** [Major surgical procedures]",
      "- **Hospitalizations:** [Recent hospital stays]",
      "- **Trauma History:** [Significant injuries]",
      "",
      "### Medications",
      "- **Current Medications:** [List with dosages]",
      "- **Allergies:** [Known drug allergies]",
      "- **Adherence:** [Patient's medication compliance]",
      "",
      "### Family History",
      "- **Family Medical History:** [Relevant conditions in family]",
      "- **Genetic Predispositions:** [Hereditary conditions]",
      "",
      "### Social History",
      "- **Occupation:** [Current employment]",
      "- **Lifestyle:** [Smoking, alcohol, exercise habits]",
      "- **Social Support:** [Family/social network]",
      "",
      "### Review of Systems",
      "- **General:** [Constitutional symptoms]",
      "- **Cardiovascular:** [Heart-related symptoms]",
      "- **Respiratory:** [Lung/breathing symptoms]",
      "- **Gastrointestinal:** [Digestive symptoms]",
      "- **Neurological:** [Nervous system symptoms]",
      "- **Musculoskeletal:** [Bone/joint symptoms]",
      "- **Psychiatric:** [Mental health symptoms]",
      "",
      "### Physical Examination",
      "- **Vital Signs:** [Blood pressure, heart rate, temperature, etc.]",
      "- **General Appearance:** [Patient's overall condition]",
      "- **System Findings:** [Key examination findings]",
      "",
      "### Assessment",
      "- **Differential Diagnoses:** [Possible conditions]",
      "- **Working Diagnosis:** [Most likely condition]",
      "- **Diagnostic Plan:** [Tests/procedures needed]",
      "",
      "### Plan",
      "- **Treatment Plan:** [Proposed interventions]",
      "- **Follow-up:** [Next steps and appointments]",
      "- **Patient Education:** [Key information provided]",
      "",
      "### Notes",
      "- **Key Points:** [Important clinical observations]",
      "- **Red Flags:** [Concerning findings requiring attention]",
      "- **Consultation Notes:** [Any specialist referrals]"
    ],
    "rules": [
      "Extract all relevant information from the transcript",
      "Organize information using standard medical anamnesis format",
      "Use clear, concise medical terminology",
      "Maintain chronological order where appropriate",
      "Include specific details mentioned by patient",
      "Flag any missing or unclear information",
      "Use bullet points for lists and structured information",
      "Maintain professional medical documentation standards",
      "Respond ONLY with the formatted markdown",
      "If information is missing, omit that section rather than inventing data"
    ],
    "transcript": "{text}"
  },
  "display": "html",
  "form": {
    "title": "Anamnesis Structuring",
    "description": "Review the structured medical anamnesis generated from your doctor-patient transcript. The AI has organized the conversation into standardized medical documentation format.",
    "fields": [
      {
        "name": "text",
        "type": "textarea",
        "label": "Doctor-Patient Transcript",
        "help": "Enter the doctor-patient conversation transcript you want to structure. Maximum 1,000,000 characters.",
        "placeholder": "Example:\nDoctor: What brings you in today?\nPatient: I've been having headaches for about a week...\n\nTip: You can also upload a text file or image of the transcript below.",
        "required": true
      },
      "file",
      "model",
      "language",
      "max_image_size"
    ]
  }
}
