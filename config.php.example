// =========================================================================
// LLM Providers
//
// Each entry defines one OpenAI-compatible provider.
//
// Fields:
//   name         Human-readable label shown in the UI
//   endpoint     Base URL of the OpenAI-compatible API (no trailing slash,
//                no /chat/completions — the backend appends those paths)
//   key          API key; use '' for local providers that need none
//   filter       PCRE regex applied to model IDs from /models; '' = no filter
//   default_model  Model name used when the form submits no model, or when
//                  the provider has no /models endpoint
//   models_api   true  → query /models to populate the model selector
//                false → skip the query and expose only default_model
// =========================================================================
$LLM_PROVIDERS = [

    'ollama' => [
        'name'          => 'Ollama (local)',
        'endpoint'      => 'http://127.0.0.1:11434/v1',
        'key'           => '',
        'filter'        => '',           // e.g. '/free/' to show only free models
        'default_model' => 'qwen2.5:1.5b',
        'models_api'    => true,
    ],

    'local' => [
        'name'          => 'llama.cpp (local)',
        'endpoint'      => 'http://127.0.0.1:8080/v1',
        'key'           => '',
        'filter'        => '',
        'default_model' => 'llama-3.2-3b-instruct',
        'models_api'    => false,        // llama.cpp does not expose /models
    ],

    'openai' => [
        'name'          => 'OpenAI',
        'endpoint'      => 'https://api.openai.com/v1',
        'key'           => 'sk-...',
        'filter'        => '/^gpt/',     // show only GPT models
        'default_model' => 'gpt-4o-mini',
        'models_api'    => true,
    ],

    'openrouter' => [
        'name'          => 'OpenRouter',
        'endpoint'      => 'https://openrouter.ai/api/v1',
        'key'           => 'sk-or-...',
        'filter'        => '',
        'default_model' => 'meta-llama/llama-3.3-70b-instruct:free',
        'models_api'    => true,
    ],

    'cerebras' => [
        'name'          => 'Cerebras',
        'endpoint'      => 'https://api.cerebras.ai/v1',
        'key'           => 'csk-...',
        'filter'        => '',
        'default_model' => 'llama-3.3-70b',
        'models_api'    => true,
    ],

    'together' => [
        'name'          => 'Together.xyz',
        'endpoint'      => 'https://api.together.xyz/v1',
        'key'           => '',
        'filter'        => '',
        'default_model' => 'meta-llama/Llama-3.3-70B-Instruct-Turbo',
        'models_api'    => true,
    ],

    'anthropic' => [
        'name'          => 'Anthropic (via proxy)',
        'endpoint'      => 'https://api.anthropic.com/v1',
        'key'           => 'sk-ant-...',
        'filter'        => '/^claude/',
        'default_model' => 'claude-sonnet-4-5',
        'models_api'    => false,        // Anthropic has no OpenAI-compatible /models
    ],

];

// =========================================================================
// Active Provider
//
// Must match one of the keys in $LLM_PROVIDERS above.
// Change this single line to switch between providers.
// =========================================================================
$LLM_ACTIVE_PROVIDER = 'ollama';

// =========================================================================
// Application Settings
// =========================================================================

/** Maximum messages kept in chat history */
$CHAT_HISTORY_LENGTH = 10;

/** Set to true to include prompt and API payload in every response */
$DEBUG_MODE = false;

/** CORS allowed origins; use ['*'] to allow all, or list specific origins */
$ALLOWED_ORIGINS = ['*'];

// =========================================================================
// File Upload Settings
// =========================================================================

$MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB

$ALLOWED_FILE_TYPES = [
    'image/jpeg',
    'image/png',
    'image/gif',
    'image/webp',
    'application/pdf',
    'text/plain',
    'text/markdown',
    'application/msword',
    'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
    'application/vnd.oasis.opendocument.text',
];

// =========================================================================
// Legacy flat variables (optional — kept for backward compatibility)
//
// If $LLM_PROVIDERS / $LLM_ACTIVE_PROVIDER are defined above, these are
// ignored. They are only used when the new provider array is absent, so
// existing single-provider installs continue to work without changes.
