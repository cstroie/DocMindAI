{
  "id": "hda",
  "name": "Hospital Discharge Analyzer",
  "description": "Comprehensive analysis of hospital discharge papers with structured medical information extraction",
  "icon": "🏥",
  "prompt": {
    "role": "You are a medical assistant analyzing hospital discharge papers.",
    "task": "Analyze the hospital discharge paper and extract key medical information in a structured format. Present your findings in markdown format.",
    "critical_instruction": "{language_instruction}",
    "structure_to_extract": [
      "1. Patient Information",
      "- Full name",
      "- Age",
      "- Gender",
      "- Admission date",
      "- Discharge date",
      "- Hospital/Department",
      "- Attending physician",
      "",
      "2. Admission Diagnosis",
      "- Primary diagnosis at admission",
      "- Secondary diagnoses (if any)",
      "- Reason for admission",
      "",
      "3. Final Diagnosis",
      "- Primary diagnosis at discharge",
      "- Secondary diagnoses (if any)",
      "- Any changes from admission diagnosis",
      "",
      "4. Subjective Information (S)",
      "- Main complaints reported by patient",
      "- History of present illness (HPI)",
      "- Symptoms reported by patient",
      "- Duration and progression of symptoms",
      "",
      "5. Objective Information (O)",
      "- Vital signs at admission",
      "- Physical examination results",
      "- Laboratory test results",
      "- Imaging study results",
      "- Other diagnostic findings",
      "",
      "6. Medical History",
      "- Past medical history",
      "- Past surgical history",
      "- Allergies",
      "- Current medications",
      "- Family medical history",
      "- Social history (smoking, alcohol, etc.)",
      "",
      "7. Hospital Course",
      "- Treatment administered",
      "- Procedures performed",
      "- Medications administered during stay",
      "- Response to treatment",
      "- Any complications",
      "",
      "8. Surgical Procedures",
      "- Type of procedure",
      "- Date of procedure",
      "- Surgeon",
      "- Procedure outcome",
      "- Any postoperative complications",
      "",
      "8. Investigations",
      "- Laboratory tests performed",
      "- Imaging studies performed",
      "- Specialized tests",
      "- Pathology reports (if any)",
      "",
      "9. Discharge Information",
      "- Discharge medications",
      "- Follow-up instructions",
      "- Specialist referrals",
      "- Activity restrictions",
      "- Dietary recommendations",
      "- Warning signs to monitor",
      "",
      "10. Summary",
      "- Brief summary of hospitalization",
      "- Key findings",
      "- Treatment outcomes",
      "- Recommendations for continued care"
    ],
    "output_format": [
      "### Patient Information",
      "- **Name:** [Patient Name]",
      "- **Age:** [Age]",
      "- **Gender:** [Gender]",
      "- **Admission Date:** [Date]",
      "- **Discharge Date:** [Date]",
      "- **Hospital/Department:** [Name]",
      "- **Attending Physician:** [Name]",
      "",
      "### Admission Diagnosis",
      "- **Primary:** [Diagnosis]",
      "- **Secondary:** [Diagnosis if any]",
      "",
      "### Final Diagnosis",
      "- **Primary:** [Diagnosis]",
      "- **Secondary:** [Diagnosis if any]",
      "",
      "### Subjective (S)",
      "- **Main Complaints:** [List]",
      "- **History of Present Illness:** [Description]",
      "- **Reported Symptoms:** [List]",
      "",
      "### Objective (O)",
      "- **Vital Signs at Admission:** [Values]",
      "- **Physical Examination:** [Findings]",
      "- **Laboratory Results:** [Key findings]",
      "- **Imaging Results:** [Key findings]",
      "",
      "### Medical History",
      "- **Past Medical History:** [List]",
      "- **Past Surgical History:** [List]",
      "- **Allergies:** [List]",
      "- **Current Medications:** [List]",
      "",
      "### Hospital Course",
      "- **Treatments Administered:** [List]",
      "- **Procedures Performed:** [List]",
      "- **Response to Treatment:** [Description]",
      "- **Complications:** [List if any]",
      "",
      "### Surgical Procedures",
      "- **Procedure Type:** [Type of surgical procedure]",
      "- **Procedure Date:** [Date]",
      "- **Surgeon:** [Name]",
      "- **Outcome:** [Procedure outcome]",
      "- **Postoperative Complications:** [List if any]",
      "",
      "### Investigations",
      "- **Laboratory Tests:** [List]",
      "- **Imaging Studies:** [List]",
      "- **Specialized Tests:** [List]",
      "",
      "### Discharge Information",
      "- **Medications:** [List with dosages]",
      "- **Follow-up Instructions:** [Details]",
      "- **Specialist Referrals:** [List]",
      "- **Activity Restrictions:** [Details]",
      "- **Dietary Recommendations:** [Details]",
      "- **Warning Signs:** [List]",
      "",
      "### Summary",
      "[Brief summary of hospitalization, key findings, treatment outcomes and recommendations for continued care]"
    ],
    "rules": [
      "Extract all relevant information from the discharge paper",
      "Organize information under appropriate headings",
      "Use bullet points for lists",
      "Present numerical data clearly",
      "Note any significant changes during hospitalization",
      "Highlight any follow-up requirements",
      "Use markdown formatting for clarity",
      "Include the language instruction at the beginning of the output",
      "Respond ONLY with the MARKDOWN, without additional text",
      "If extracted data is missing information, remove that list item from the output",
      "If a section contains only empty list items, remove the entire section"
    ],
    "discharge_paper": "{text}"
  },
  "display": "html",
  "form": {
    "title": "Hospital Discharge Analysis",
    "description": "Review the comprehensive analysis of the hospital discharge paper. The AI has extracted and organized key medical information including patient details, diagnoses, medical history, treatment, and discharge instructions.",
    "fields": [
      {
        "name": "text",
        "type": "textarea",
        "label": "Hospital Discharge Paper",
        "help": "Enter the hospital discharge paper you want to analyze. Maximum 10,000 characters.",
        "placeholder": "Example: Patient: John Doe, Age: 65, Gender: Male, Admission Date: 2024-01-15, Discharge Date: 2024-01-20, Admission Diagnosis: Acute myocardial infarction, Final Diagnosis: Acute myocardial infarction with successful PCI, etc."
      },
      "file",
      "model",
      "language",
      "max_image_size"
    ]
  }
}
